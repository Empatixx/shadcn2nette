{default $class = ''}
<div value="{{
          carouselRef,
          api: api,
          opts,
          orientation:
            orientation || (opts?.axis === "y" ? "vertical" : "horizontal"),
          scrollPrev,
          scrollNext,
          canScrollPrev,
          canScrollNext,
        }}">
	<div class="relative {$class}" role="region" aria-roledescription="carousel">
		{block content}{/block}
	</div>
</div>
