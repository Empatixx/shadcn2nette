<!doctype html>
<html lang="en" class="">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>shadcn2nette — composition demo</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/assets/app.css">
</head>
<body class="bg-background text-foreground min-h-screen antialiased">
	<div class="mx-auto max-w-3xl px-6 py-12 space-y-10">

		<header class="flex items-center justify-between">
			<div class="space-y-1">
				<h1 class="text-2xl font-semibold tracking-tight">shadcn2nette</h1>
				<p class="text-sm text-muted-foreground">shadcn/ui components, transpiled to Nette .phtml (Latte), composed on this page.</p>
			</div>
			<button onclick="document.documentElement.classList.toggle('dark')"
				class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground">
				Toggle theme
			</button>
		</header>

		<section class="space-y-3">
			<h2 class="text-sm font-medium text-muted-foreground">Buttons</h2>
			<div class="flex flex-wrap items-center gap-3">
				{embed 'components/button.phtml', variant: 'default'}{block content}Default{/block}{/embed}
				{embed 'components/button.phtml', variant: 'secondary'}{block content}Secondary{/block}{/embed}
				{embed 'components/button.phtml', variant: 'destructive'}{block content}Destructive{/block}{/embed}
				{embed 'components/button.phtml', variant: 'outline'}{block content}Outline{/block}{/embed}
				{embed 'components/button.phtml', variant: 'ghost'}{block content}Ghost{/block}{/embed}
				{embed 'components/button.phtml', variant: 'link'}{block content}Link{/block}{/embed}
			</div>
			<div class="flex flex-wrap items-center gap-3">
				{embed 'components/button.phtml', size: 'sm'}{block content}Small{/block}{/embed}
				{embed 'components/button.phtml'}{block content}Default size{/block}{/embed}
				{embed 'components/button.phtml', size: 'lg'}{block content}Large{/block}{/embed}
			</div>
		</section>

		<section class="space-y-3">
			<h2 class="text-sm font-medium text-muted-foreground">Badges</h2>
			<div class="flex flex-wrap items-center gap-3">
				{embed 'components/badge.phtml', variant: 'default'}{block content}Default{/block}{/embed}
				{embed 'components/badge.phtml', variant: 'secondary'}{block content}Secondary{/block}{/embed}
				{embed 'components/badge.phtml', variant: 'destructive'}{block content}Destructive{/block}{/embed}
				{embed 'components/badge.phtml', variant: 'outline'}{block content}Outline{/block}{/embed}
			</div>
		</section>

		<section class="space-y-3">
			<h2 class="text-sm font-medium text-muted-foreground">Alert</h2>
			{embed 'components/alert.phtml'}{block content}
				{embed 'components/alert-title.phtml'}{block content}Heads up{/block}{/embed}
				{embed 'components/alert-description.phtml'}{block content}This alert is composed from transpiled templates.{/block}{/embed}
			{/block}{/embed}
			{embed 'components/alert.phtml', variant: 'destructive'}{block content}
				{embed 'components/alert-title.phtml'}{block content}Something needs attention{/block}{/embed}
				{embed 'components/alert-description.phtml'}{block content}The destructive variant uses theme tokens.{/block}{/embed}
			{/block}{/embed}
		</section>

		<section class="space-y-3">
			<h2 class="text-sm font-medium text-muted-foreground">Card composed from parts</h2>
			{embed 'components/card.phtml', class: 'max-w-md'}{block content}
				{embed 'components/card-header.phtml'}{block content}
					{embed 'components/card-title.phtml'}{block content}Create account{/block}{/embed}
					{embed 'components/card-description.phtml'}{block content}Enter your email to get started.{/block}{/embed}
				{/block}{/embed}
				{embed 'components/card-content.phtml'}{block content}
					<div class="space-y-2">
						{embed 'components/label.phtml'}{block content}Email{/block}{/embed}
						{embed 'components/input.phtml', type: 'email'}{/embed}
					</div>
				{/block}{/embed}
				{embed 'components/card-footer.phtml', class: 'gap-3'}{block content}
					{embed 'components/button.phtml', variant: 'outline'}{block content}Cancel{/block}{/embed}
					{embed 'components/button.phtml'}{block content}Sign up{/block}{/embed}
				{/block}{/embed}
			{/block}{/embed}
		</section>

		<section class="space-y-3">
			<h2 class="text-sm font-medium text-muted-foreground">Avatar, separator & skeleton</h2>
			<div class="flex items-center gap-4">
				{embed 'components/avatar.phtml'}{block content}
					{embed 'components/avatar-fallback.phtml'}{block content}SN{/block}{/embed}
				{/block}{/embed}
				{embed 'components/separator.phtml', class: 'h-8 w-px'}{/embed}
				<div class="space-y-2">
					{embed 'components/skeleton.phtml', class: 'h-4 w-[160px]'}{/embed}
					{embed 'components/skeleton.phtml', class: 'h-4 w-[110px]'}{/embed}
				</div>
			</div>
		</section>

	</div>
</body>
</html>
