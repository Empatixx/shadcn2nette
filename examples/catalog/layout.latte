<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>shadcn2nette — catalog</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/assets/app.css">
	<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/anchor@3.x.x/dist/cdn.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/focus@3.x.x/dist/cdn.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-background text-foreground antialiased">
	<div class="flex min-h-screen">

		<aside class="sticky top-0 h-screen w-64 shrink-0 overflow-y-auto border-r border-border p-4">
			<div class="mb-4">
				<h1 class="text-base font-semibold tracking-tight">shadcn2nette</h1>
				<p class="text-xs text-muted-foreground">{count($names)} components</p>
			</div>
			<input id="filter" type="text" placeholder="Filter…"
				class="mb-3 flex h-8 w-full rounded-md border border-input bg-transparent px-3 text-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
			<nav id="nav" class="space-y-0.5">
				{foreach $names as $name}
					<a href="?c={$name}" data-name="{$name}"
						class="block rounded-md px-3 py-1.5 text-sm {if $name === $selected}bg-accent text-accent-foreground font-medium{else}text-muted-foreground hover:bg-accent hover:text-accent-foreground{/if}">
						{$name}
					</a>
				{/foreach}
			</nav>
		</aside>

		<main class="min-w-0 flex-1 p-8">
			<div class="mb-6 flex items-center justify-between gap-4">
				<div>
					<h2 class="text-2xl font-semibold tracking-tight">{$title}</h2>
					<p class="text-sm text-muted-foreground">{count($entries)} template(s) · rendered by the Nette Latte engine</p>
				</div>
				<div class="flex items-center gap-2">
					<a href="?view=compare" class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground">Compare</a>
					<a href="?view=interactive" class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground">Interactive</a>
					<a href="?view=showcase" class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground">Showcase</a>
					<button onclick="document.documentElement.classList.toggle('dark')" class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground">Theme</button>
				</div>
			</div>

			<div class="space-y-6">
				{foreach $entries as $entry}
					<section class="rounded-lg border border-border">
						<div class="border-b border-border px-4 py-2 text-sm font-medium">{$entry['label']}<span class="ml-2 font-mono text-xs text-muted-foreground">{$entry['file']}</span></div>
						<div class="flex min-h-24 items-center justify-center gap-3 bg-muted/40 p-8">
							{$entry['preview']|noescape}
						</div>
						<details class="border-t border-border">
							<summary class="cursor-pointer px-4 py-2 text-xs text-muted-foreground hover:text-foreground">View .phtml source</summary>
							<pre class="overflow-x-auto border-t border-border bg-muted/30 p-4 text-xs leading-relaxed"><code>{$entry['source']}</code></pre>
						</details>
					</section>
				{/foreach}
			</div>
		</main>
	</div>

	<script>
		const filter = document.getElementById('filter');
		filter.addEventListener('input', () => {
			const q = filter.value.toLowerCase();
			document.querySelectorAll('#nav a').forEach((a) => {
				a.style.display = a.dataset.name.includes(q) ? '' : 'none';
			});
		});
	</script>
</body>
</html>
