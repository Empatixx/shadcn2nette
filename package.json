{
  "name": "shadcn2nette",
  "version": "0.1.0",
  "description": "Transpile shadcn/ui components into Nette .phtml (Latte) templates",
  "type": "module",
  "bin": {
    "shadcn2nette": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "transpile": "tsx src/cli.ts",
    "demo": "bun examples/serve.ts",
    "build:css": "cd reference && bunx @tailwindcss/cli@4 -i nette-build.css -o ../assets/app.css --minify"
  },
  "dependencies": {
    "@zag-js/accordion": "^1.41.2",
    "@zag-js/switch": "^1.41.2",
    "@zag-js/vanilla": "^1.41.2",
    "commander": "^12.1.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}
